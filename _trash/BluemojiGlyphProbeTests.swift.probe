//  BluemojiGlyphProbeTests.swift  (temporary empirical probe — safe to delete)
//  Answers: does NSAdaptiveImageGlyph(imageContent:) render a plain PNG blob?
import XCTest
import UIKit
import UniformTypeIdentifiers

final class BluemojiGlyphProbeTests: XCTestCase {

  // Real blue.moji png_128 blob (did:plc:w5pfavrjij2ax3ur34tvbkg2 / :test1:)
  static let pngBase64 = """

"""

  private func pngData() -> Data { Data(base64Encoded: Self.pngBase64.replacingOccurrences(of: "\n", with: ""))! }

  // Count pixels that are meaningfully colored (not transparent, not pure text-black/white).
  private func coloredPixelCount(_ image: UIImage) -> Int {
    guard let cg = image.cgImage else { return 0 }
    let w = cg.width, h = cg.height
    let bytesPerRow = w * 4
    var buf = [UInt8](repeating: 0, count: bytesPerRow * h)
    let cs = CGColorSpaceCreateDeviceRGB()
    let ctx = CGContext(data: &buf, width: w, height: h, bitsPerComponent: 8,
                        bytesPerRow: bytesPerRow, space: cs,
                        bitmapInfo: CGImageAlphaInfo.premultipliedLast.rawValue)!
    ctx.draw(cg, in: CGRect(x: 0, y: 0, width: w, height: h))
    var colored = 0
    var i = 0
    while i < buf.count {
      let r = buf[i], g = buf[i+1], b = buf[i+2], a = buf[i+3]
      if a > 40 {
        let mx = max(r, max(g, b)), mn = min(r, min(g, b))
        // chroma present (a blue cat has saturation) OR mid-gray fill
        if Int(mx) - Int(mn) > 24 { colored += 1 }
      }
      i += 4
    }
    return colored
  }

  private func snapshot(_ v: UIView) -> UIImage {
    let r = UIGraphicsImageRenderer(bounds: v.bounds)
    return r.image { _ in v.drawHierarchy(in: v.bounds, afterScreenUpdates: true) }
  }

  @MainActor
  func testAdaptiveImageGlyphRendersPlainPNG() throws {
    guard #available(iOS 18.0, *) else { throw XCTSkip("needs iOS 18") }

    func render(_ s: NSAttributedString) -> UIImage {
      let tv = UITextView(frame: CGRect(x: 0, y: 0, width: 300, height: 80))
      tv.backgroundColor = .white
      tv.textColor = .black
      if #available(iOS 18.0, *) { tv.supportsAdaptiveImageGlyph = true }
      tv.attributedText = s
      tv.layoutIfNeeded()
      tv.layoutManager.ensureLayout(for: tv.textContainer)
      return snapshot(tv)
    }
    func glyphStr(_ g: NSAdaptiveImageGlyph?) -> (nilGlyph: Bool, colored: Int) {
      guard let g else { return (true, -1) }
      let s = NSMutableAttributedString(string: "AA \u{FFFC} AA",
        attributes: [.font: UIFont.systemFont(ofSize: 40)])
      s.addAttribute(.adaptiveImageGlyph, value: g, range: (s.string as NSString).range(of: "\u{FFFC}"))
      return (false, coloredPixelCount(render(s)))
    }

    let baseColored = coloredPixelCount(
      render(NSAttributedString(string: "AA A AA", attributes: [.font: UIFont.systemFont(ofSize: 40)])))

    // Data point 1: raw PNG as imageContent. The Obj-C init can return nil → nil-bridged into
    // a non-optional Swift value; re-treat as optional to detect rejection without crashing.
    let rawPNG = Optional(NSAdaptiveImageGlyph(imageContent: pngData()))
    let png = glyphStr(rawPNG)

    // Data point 2: transcode the PNG to a bare HEIC and try that as imageContent.
    var heic: (nilGlyph: Bool, colored: Int) = (true, -1)
    if let cg = UIImage(data: pngData())?.cgImage {
      let data = NSMutableData()
      if let dest = CGImageDestinationCreateWithData(data, UTType.heic.identifier as CFString, 1, nil) {
        CGImageDestinationAddImage(dest, cg, nil)
        if CGImageDestinationFinalize(dest) {
          heic = glyphStr(Optional(NSAdaptiveImageGlyph(imageContent: data as Data)))
        }
      }
    }

    // Data point 3: NSTextAttachment with the PNG (the fallback approach) — proves the pixel
    // harness CAN detect an inline image, and that NSTextAttachment renders it.
    let att = NSTextAttachment()
    att.image = UIImage(data: pngData())
    att.bounds = CGRect(x: 0, y: -8, width: 40, height: 40)
    let attStr = NSMutableAttributedString(string: "AA ", attributes: [.font: UIFont.systemFont(ofSize: 40)])
    attStr.append(NSAttributedString(attachment: att))
    attStr.append(NSAttributedString(string: " AA", attributes: [.font: UIFont.systemFont(ofSize: 40)]))
    let attachColored = coloredPixelCount(render(attStr))

    let result = """
    PROBE RESULTS:
      baseColored (plain text)              = \(baseColored)
      rawPNG glyph returned nil?            = \(png.nilGlyph)   colored=\(png.colored)
      HEIC glyph returned nil?              = \(heic.nilGlyph)   colored=\(heic.colored)
      NSTextAttachment colored              = \(attachColored)
    """
    NSLog("%@", result)
    // Surface via failure text (reliably parseable from the .xcresult test-details node name).
    XCTFail("DATAPROBE|| \(result.replacingOccurrences(of: "\n", with: " || "))")
  }
}
